```gitignore
# Compiled and build artifacts
*.js.map
*.tsbuildinfo
dist/
build/
*.o
*.obj
*.pyc
__pycache__/

# Dependencies
node_modules/
.venv/
venv/
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# System
.DS_Store
Thumbs.db

# Testing and coverage
.coverage
coverage/
htmlcov/
.mypy_cache/
.pytest_cache/

# Distribution packages
*.tar.gz
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
```